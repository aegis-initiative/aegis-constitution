---
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = 'AEGIS™ Constitution';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/AEGIS_logo.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Prevent FOUC: apply theme before paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('aegis-theme');
        const theme = stored === 'light' || stored === 'dark' ? stored
          : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>

  <body>
    <Header />

    <div class="layout">
      <Sidebar />

      <div class="content-wrapper">
        <main class="content" id="main-content">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style is:global>
  /* ─── Font faces ─────────────────────────────────────────── */

  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-variablefont_wdthwght-webfont.woff2") format("woff2-variations");
    font-weight: 100 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "IBM Plex Sans";
    src: url("/fonts/ibmplexsans-italic-variablefont_wdthwght-webfont.woff2") format("woff2-variations");
    font-weight: 100 700;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-light-webfont.woff2") format("woff2");
    font-weight: 300;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-lightitalic-webfont.woff2") format("woff2");
    font-weight: 300;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-regular-webfont.woff2") format("woff2");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-italic-webfont.woff2") format("woff2");
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-medium-webfont.woff2") format("woff2");
    font-weight: 500;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-mediumitalic-webfont.woff2") format("woff2");
    font-weight: 500;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-semibold-webfont.woff2") format("woff2");
    font-weight: 600;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "Poppins";
    src: url("/fonts/poppins-semibolditalic-webfont.woff2") format("woff2");
    font-weight: 600;
    font-style: italic;
    font-display: swap;
  }

  /* ─── Design tokens ──────────────────────────────────────── */

  :root,
  [data-theme="light"] {
    /* Grays — light theme (dark values, ascending) */
    --color-white:   #161616;
    --color-gray-1:  #272727;
    --color-gray-2:  #383838;
    --color-gray-3:  #484848;   /* 9.15:1 on white — WCAG AA ✓ */
    --color-gray-4:  #595959;   /* 7.00:1 on white — WCAG AA ✓ */
    --color-gray-5:  #909090;   /* border/decorative only */
    --color-gray-6:  #c8c8c8;   /* border/decorative only */
    --color-black:   #ffffff;

    /* Semantic */
    --color-bg:             var(--color-black);
    --color-bg-subtle:      #f4f4f4;
    --color-bg-muted:       #ececec;
    --color-text:           var(--color-white);
    --color-text-secondary: var(--color-gray-3);
    --color-text-muted:     var(--color-gray-4);
    --color-border:         var(--color-gray-5);
    --color-border-subtle:  var(--color-gray-6);
    --color-accent:         #0062a5;   /* accessible blue — 4.5:1+ on white */
    --color-accent-brand:   #0084e7;   /* brand blue — decorative only */

    /* Component */
    --header-bg:   var(--color-black);
    --sidebar-bg:  #f8f8f8;
  }

  [data-theme="dark"] {
    /* Grays — dark theme (light values, descending) */
    --color-white:   #ffffff;
    --color-gray-1:  #fcfcfc;
    --color-gray-2:  #f8f8f8;
    --color-gray-3:  #f4f4f4;   /* 15:1 on dark bg — WCAG AAA ✓ */
    --color-gray-4:  #a1a1a1;   /* 7.00:1 on dark bg — WCAG AA ✓ */
    --color-gray-5:  #595959;   /* border/decorative only */
    --color-gray-6:  #444444;   /* border/decorative only */
    --color-black:   #161616;

    /* Semantic */
    --color-bg:             var(--color-black);
    --color-bg-subtle:      #1e1e1e;
    --color-bg-muted:       #252525;
    --color-text:           var(--color-white);
    --color-text-secondary: var(--color-gray-3);
    --color-text-muted:     var(--color-gray-4);
    --color-border:         var(--color-gray-5);
    --color-border-subtle:  var(--color-gray-6);
    --color-accent:         #0084e7;   /* brand blue passes on dark bg */
    --color-accent-brand:   #0084e7;

    /* Component */
    --header-bg:   #111111;
    --sidebar-bg:  #1a1a1a;
  }

  /* ─── Reset & base ───────────────────────────────────────── */

  *, *::before, *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  /* ─── Layout shell ───────────────────────────────────────── */

  .layout {
    display: flex;
    min-height: calc(100vh - 3.5rem); /* subtract header height */
  }

  .content-wrapper {
    flex: 1;
    min-width: 0; /* prevent flex overflow */
    display: flex;
    flex-direction: column;
  }

  .content {
    flex: 1;
    padding: 2rem 1.5rem;
    max-width: 56rem;
    width: 100%;
  }

  @media (min-width: 768px) {
    .content {
      padding: 2.5rem 2.5rem;
    }
  }

  /* ─── Typography ─────────────────────────────────────────── */

  h1, h2, h3, h4, h5, h6 {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  h1 { font-size: 2rem; margin-top: 0; }
  h2 { font-size: 1.5rem; }
  h3 { font-size: 1.25rem; }
  h4 { font-size: 1.125rem; }

  p {
    margin-top: 0;
    margin-bottom: 1rem;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  a:hover {
    opacity: 0.85;
  }

  /* ─── Prose content ──────────────────────────────────────── */

  .content ul,
  .content ol {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .content li {
    margin-bottom: 0.25rem;
  }

  .content blockquote {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid var(--color-accent-brand);
    background-color: var(--color-bg-subtle);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .content code {
    font-size: 0.875em;
    padding: 0.15em 0.4em;
    background-color: var(--color-bg-subtle);
    border-radius: 3px;
    font-family: "SFMono-Regular", "Consolas", "Liberation Mono", monospace;
  }

  /* Dark theme inline code contrast fix */
  [data-theme="dark"] .content code {
    background-color: #2d2d2d;
    color: var(--color-gray-2);
  }

  .content pre {
    padding: 1.25rem;
    background-color: var(--color-bg-subtle);
    border-radius: 6px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-border-subtle);
  }

  .content pre code {
    padding: 0;
    background: none;
    font-size: 0.875rem;
  }

  .content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .content th {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 0.75rem;
    border-bottom: 2px solid var(--color-border);
    color: var(--color-text);
  }

  .content td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-secondary);
  }

  .content hr {
    border: none;
    border-top: 1px solid var(--color-border-subtle);
    margin: 2rem 0;
  }

  /* ─── Accessibility ──────────────────────────────────────── */

  :focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
