---
/**
 * Site-specific Header wrapper.
 * Delegates to the shared design-system Header with constitution-specific props.
 */
import SharedHeader from '@aegis-initiative/design-system/components/Header.astro';
---

<SharedHeader
  siteName="AEGIS Constitution"
  githubUrl="https://github.com/aegis-initiative"
  showVersion={true}
  showPdf={true}
  pdfUrls={{ print: '/AEGIS_Constitution_print.pdf', download: '/AEGIS_Constitution.pdf' }}
/>
