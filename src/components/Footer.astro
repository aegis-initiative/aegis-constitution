---
const year = new Date().getFullYear();
const version = import.meta.env.AEGIS_VERSION ?? 'dev';

const nav = [
  { label: 'Constitution', href: '/constitution/' },
  { label: 'Doctrine', href: '/doctrine/' },
  { label: 'Principles', href: '/principles/' },
  { label: 'Protocols', href: '/protocols/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Legal', href: '/legal/' },
  { label: 'Terms', href: '/legal/terms/' },
  { label: 'Privacy', href: '/legal/privacy/' },
];
---

<footer class="site-footer">
  <nav class="footer-nav" aria-label="Footer navigation">
    {nav.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </nav>
  <hr class="footer-divider" />
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-author">
        Built and maintained by <a href="https://finnoybu.github.io/">Ken Tannenbaum</a>
      </span>
      <span class="footer-meta">Version: {version}</span>
    </div>
    <div class="footer-right">
      <span>© {year} <a href="/legal/">AEGIS Initiative</a>. All Rights Reserved.</span>
      <span class="footer-meta">This site is operated by AEGIS Operations LLC</span>
      <span class="footer-meta">under license from AEGIS Initiative.</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border-subtle);
    padding: 1.25rem 1.5rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg);
  }

  .footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.5rem;
    padding-bottom: 1rem;
  }

  .footer-nav a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    white-space: nowrap;
    font-size: 0.875rem;
  }

  .footer-nav a:hover {
    color: var(--color-accent);
  }

  .footer-divider {
    border: none;
    border-top: 1px solid var(--color-border-subtle);
    margin: 0 0 1rem;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    align-items: center;
  }

  .footer-author a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .footer-meta {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  @media (min-width: 768px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      text-align: left;
    }

    .footer-left {
      align-items: flex-start;
    }

    .footer-right {
      align-items: flex-end;
      text-align: right;
    }
  }
</style>